# ============================================
# UPGRADE TO TWINTOKEN - ENVIRONMENT VARIABLES
# ============================================

# 1. DEPLOYER (debe ser el owner del Beacon)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# 2. ADDRESSES DEL TOKEN DEPLOYADO (pedir al TL)
TOKEN_PROXY_ADDRESS=0x...    # Address del NumToken proxy
BEACON_ADDRESS=0x...         # Address del UpgradeableBeacon
FORWARDER_ADDRESS=0x...      # Address del ERC2771 forwarder (debe coincidir con el actual)

# 3. NUEVO NOMBRE Y SIMBOLO
NEW_TOKEN_NAME="Twin Token"
NEW_TOKEN_SYMBOL="TWIN"

# 4. RPC URL (según la red donde esté deployado)
# Ejemplos:
# Sepolia: https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Polygon Mumbai: https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Arbitrum Sepolia: https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# 5. OPCIONAL: Addresses para verificar balances después del upgrade (separadas por coma)
CHECK_BALANCES=0xAddress1,0xAddress2,0xAddress3

# 6. OPCIONAL: Para verificar en Etherscan
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
